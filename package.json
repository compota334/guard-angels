{
  "name": "@guard-angels/cli",
  "version": "0.3.0",
  "description": "CLI orchestrator that creates per-folder angel agents for persistent codebase context",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "angels": "dist/bin/angels.js"
  },
  "files": [
    "dist/",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "prepack": "node -e \"if (!require('node:fs').existsSync('dist/bin/angels.js')) { console.error('dist/ is missing or incomplete - run npm run build before packing'); process.exit(1); }\"",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "cli",
    "ai",
    "agents",
    "codebase",
    "context",
    "orchestrator",
    "llm",
    "claude",
    "developer-tools",
    "code-assistant",
    "multi-agent"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/compota334/guard-angels.git"
  },
  "homepage": "https://github.com/compota334/guard-angels#readme",
  "bugs": {
    "url": "https://github.com/compota334/guard-angels/issues"
  },
  "dependencies": {
    "commander": "14.0.3",
    "execa": "9.6.1",
    "yaml": "2.8.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.6.0",
    "eslint": "10.2.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.1",
    "vitest": "4.1.5"
  }
}
